---
interface TimelineItem {
  side: "left" | "right";
  heading: string;
  text: string;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;

const headingClass =
  "m-0 mb-1 font-bold text-xs uppercase tracking-[0.2em] opacity-40 print:text-gray-600 md:text-sm";
---

<div class="cv-timeline relative mx-auto max-w-4xl pt-2 print:pt-0">
  <div
    class="cv-timeline-rail pointer-events-none absolute left-1/2 top-[1rem] -bottom-10 z-0 w-0.5 -translate-x-1/2 bg-[#3BA590]/80 print:hidden"
    aria-hidden="true"
  >
  </div>

  <ul
    class="cv-timeline-list relative z-[1] m-0 list-none space-y-8 p-0 print:space-y-0"
  >
    {
      items.map((item) => (
        <li class="cv-timeline-row grid grid-cols-[minmax(0,1fr)_2.75rem_minmax(0,1fr)] items-center gap-x-2 gap-y-2 md:grid-cols-[minmax(0,1fr)_3.5rem_minmax(0,1fr)] md:gap-x-4 print:mb-1">
          {item.side === "left" ? (
            <div class="cv-timeline-cell -my-8 min-w-0 text-right text-sm leading-snug print:text-left md:text-base">
              <h3 class={headingClass}>{item.heading}</h3>
              {item.text ? <span set:html={item.text} /> : null}
            </div>
          ) : (
            <div
              class="cv-timeline-cell cv-timeline-cell--empty min-w-0"
              aria-hidden="true"
            />
          )}

          <div
            class:list={[
              "cv-timeline-marker flex h-full min-h-[1.25rem] justify-center print:hidden",
              item.side === "left" ? "-mt-14" : "mt-2",
            ]}
          >
            <span
              class="mt-0.5 h-2.5 w-2.5 shrink-0 rounded-full border-2 border-[#3BA590] bg-[#F7FDED] print:border-[#000] print:bg-white"
              aria-hidden="true"
            />
          </div>

          {item.side === "right" ? (
            <div class="cv-timeline-cell min-w-0 text-left text-sm leading-snug md:text-base">
              <h3 class={headingClass}>{item.heading}</h3>
              {item.text ? <span set:html={item.text} /> : null}
            </div>
          ) : (
            <div
              class="cv-timeline-cell cv-timeline-cell--empty min-w-0"
              aria-hidden="true"
            />
          )}
        </li>
      ))
    }
  </ul>
</div>
