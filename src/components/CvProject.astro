---
import { withBase } from "../utils/withBase";

interface Props {
  title: string;
  url?: string;
  imageUrl?: string;
  imageAlt?: string;
  tags?: string[];
}

const { title, url, imageUrl, imageAlt, tags = [] } = Astro.props;
const hasUrl = Boolean(url?.trim());
const hasImage = Boolean(imageUrl?.trim());
const hasTags = tags.length > 0;
---

<article>
  {
    hasImage ? (
      <img
        src={withBase(imageUrl!, import.meta.env.BASE_URL)}
        alt={imageAlt ?? title}
        class="w-full rounded object-cover object-top aspect-video bg-gray-600"
        loading="lazy"
      />
    ) : (
      <div class="w-full rounded aspect-video bg-gray-600" aria-hidden="true" />
    )
  }
  <h3 class="mb-2 mt-3 flex items-center text-2xl text-[#F0B356] font-semibold">
    {
      hasUrl ? (
        <a
          href={url}
          target="_blank"
          class="flex items-baseline justify-between gap-4 rounded-md py-1 transition-colors hover:bg-white/20"
          rel="noreferrer noopener"
          aria-label={`${title} (external link)`}
        >
          <span>{title}</span>
          <img
            src={withBase("/images/link.svg", import.meta.env.BASE_URL)}
            alt=""
            class="h-6 w-6"
          />
        </a>
      ) : (
        title
      )
    }
  </h3>

  <p class="font-medium"><slot /></p>

  {
    hasTags ? (
      <ul class="mt-3 flex flex-wrap gap-1.5 inline-flex">
        {tags.map((tag) => (
          <li class="rounded bg-white/10 px-1.5 py-0.5 text-sm font-medium text-[#E7E5DF]">
            {tag}
          </li>
        ))}
      </ul>
    ) : null
  }
</article>
