---
import "../styles/global.css";
import type { CvData } from "../types/cv-data";
import { withBase } from "../utils/withBase";
import CvList from "./CvList.astro";
import CvTimeline from "./CvTimeline.astro";
import CvProject from "./CvProject.astro";
import CvSection from "./CvSection.astro";

interface Props {
  data: CvData;
  alternateHref: string;
  alternateFlagSrc: string;
  alternateFlagAlt: string;
  pdfHref: string;
}

const { data, alternateHref, alternateFlagSrc, alternateFlagAlt, pdfHref } =
  Astro.props;

const withProjectBase = (value: string) => withBase(value, import.meta.env.BASE_URL);
const featuredProjectsPreviewCount = 4;
const hasMoreFeaturedProjects =
  data.projects.items.length > featuredProjectsPreviewCount;
---

<!doctype html>
<html lang={data.meta.lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={data.meta.description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{data.person.name} - CV</title>
  </head>
  <body class="bg-[#F7FDED] text-[#333] antialiased">
    <main class="min-h-screen">
      <div
        class="sticky top-0 z-20 bg-[#1B222B] py-5 mx-auto shadow-[0_0_4px_2px_#1B222Bcc]"
      >
        <div
          class="mx-auto flex w-full max-w-5xl pl-4 lg:pl-0 pr-24 flex-wrap items-center justify-between gap-3"
        >
          <div class="fixed right-2 top-5 z-20 flex items-center gap-0.5 print-hidden">
            <a
              href={withProjectBase(pdfHref)}
              download
              class="inline-flex rounded p-2 transition hover:bg-white/10"
              aria-label={data.pdfDownloadLabel}
            >
              <img
                src={withProjectBase("/images/pdf.svg")}
                alt=""
                class="h-6 w-6 brightness-0 invert opacity-90"
              />
            </a>
            <a
              href={withProjectBase(alternateHref)}
              class="inline-flex rounded p-2 transition hover:bg-white/10"
            >
              <img
                src={withProjectBase(alternateFlagSrc)}
                alt={alternateFlagAlt}
                class="h-6 w-6"
              />
            </a>
          </div>
          <h1 class="text-4xl font-light leading-none text-[#3BA590]">
            {data.person.name}
          </h1>
          <div
            class="flex flex-wrap items-center md:justify-end gap-x-10 gap-y-3 text-[#F7FDED]"
          >
            <div class="flex items-center">
              <img
                src={withProjectBase("/images/phone.svg")}
                alt={data.person.phoneLabel}
                class="mr-3 h-6 w-6"
              />
              <a
                href={data.person.phoneHref}
                class="no-underline inline-flex items-center rounded p-2 transition hover:bg-white/10"
                >{data.person.phone}</a
              >
            </div>
            <div class="flex items-center">
              <img
                src={withProjectBase("/images/email.svg")}
                alt={data.person.emailLabel}
                class="mr-3 h-6 w-6"
              />
              <a
                href={data.person.emailHref}
                class="no-underline inline-flex items-center rounded p-2 transition hover:bg-white/10"
                >{data.person.email}</a
              >
            </div>
          </div>
        </div>
      </div>

      <section class="bg-[#1B222B] px-4 pb-10 text-[#afafaf] md:pb-20 md:pt-6">
        <div class="mx-auto max-w-5xl space-y-4 text-base md:text-lg">
          {
            data.intro.map((paragraph, index) =>
              index === data.intro.length - 1 ? (
                <p>
                  <span class="print:hidden" set:html={paragraph} />
                </p>
              ) : (
                <p set:html={paragraph} />
              ),
            )
          }
        </div>
      </section>

      <CvSection title={data.skills.title}>
        <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
          {
            data.skills.items.map((item) => (
              <CvList title={item.title} items={item.list} />
            ))
          }
        </div>
      </CvSection>

      <CvSection
        title={data.projects.title}
        inverted
        sectionClass="featured-projects"
      >
        <div class="grid gap-16 md:grid-cols-2">
          {
            data.projects.items.map((project, index) => (
              <div
                class:list={[
                  index >= featuredProjectsPreviewCount ? "js-featured-project-extra hidden" : "",
                ]}
              >
                <CvProject
                  title={project.title}
                  url={project.url}
                  imageUrl={project.image}
                  imageAlt={project.imageAlt}
                  tags={project.tags}
                >
                  {project.description}
                </CvProject>
              </div>
            ))
          }
        </div>
        {
          hasMoreFeaturedProjects ? (
            <button
              type="button"
              class="js-featured-projects-expand mt-10 flex w-[calc(100%+1rem)] items-center gap-4 rounded-md text-[#E7E5DF] transition hover:bg-white/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#3BA590] cursor-pointer py-1 px-2 -mx-2 opacity-70 hover:opacity-100"
            >
              <span class="h-0 w-full border-t-2 border-[#3BA590]" aria-hidden="true" />
              <div class="whitespace-nowrap text-xs font-semibold tracking-wide flex flex-col items-center gap-0.5 text-[#3BA590] uppercase">
                {data.projects.moreProjectsButton}
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                  <path fill-rule="evenodd" d="M1.646 6.646a.5.5 0 0 1 .708 0L8 12.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708"></path>
                  <path fill-rule="evenodd" d="M1.646 2.646a.5.5 0 0 1 .708 0L8 8.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708"></path>
                </svg>
              </div>
              <span class="h-0 w-full border-t-2 border-[#3BA590]" aria-hidden="true" />
            </button>
          ) : null
        }
      </CvSection>

      <CvSection title={data.tools.title} sectionClass="tools-section">
        <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
          {
            data.tools.items.map((item) => (
              <CvList title={item.title} items={item.list} />
            ))
          }
        </div>
      </CvSection>

      <CvSection
        title={data.employment.title}
        sectionClass="employment-section"
        contentClass="pb-0 md:pb-0"
      >
        <CvTimeline items={data.employment.items} />
      </CvSection>

      <CvSection
        title={data.education.title}
        sectionClass="education-section"
        contentClass="pb-0 md:pb-0"
      >
        <div class="grid gap-10 md:grid-cols-3">
          {
            data.education.items.map((item) => (
              <CvList title={item.title} items={item.list} />
            ))
          }
        </div>
      </CvSection>
    </main>
    <footer class="mx-auto max-w-5xl px-4 py-8 text-sm text-[#666]">
      {data.footer}
    </footer>
    {
      hasMoreFeaturedProjects ? (
        <script>
          document
            .querySelector(".js-featured-projects-expand")
            ?.addEventListener("click", (event) => {
              const expandButton = event.currentTarget as HTMLElement;
              expandButton.classList.add("hidden");
              document
                .querySelectorAll(".js-featured-project-extra")
                .forEach((project) => project.classList.remove("hidden"));
            });
        </script>
      ) : null
    }
  </body>
</html>
