---
import "../styles/global.css";
import type { CvData } from "../types/cv-data";
import CvList from "./CvList.astro";
import CvTimeline from "./CvTimeline.astro";
import CvProject from "./CvProject.astro";
import CvSection from "./CvSection.astro";

interface Props {
  data: CvData;
  alternateHref: string;
  alternateFlagSrc: string;
  alternateFlagAlt: string;
  pdfHref: string;
}

const { data, alternateHref, alternateFlagSrc, alternateFlagAlt, pdfHref } =
  Astro.props;
const withBase = (value: string) =>
  value.startsWith("http://") || value.startsWith("https://")
    ? value
    : `${import.meta.env.BASE_URL}${value.replace(/^\/+/, "")}`;
---

<!doctype html>
<html lang={data.meta.lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={data.meta.description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{data.person.name} - CV</title>
  </head>
  <body class="bg-[#F7FDED] text-[#333] antialiased">
    <main class="min-h-screen">
      <div
        class="sticky top-0 z-20 bg-[#1B222B] py-5 mx-auto shadow-[0_0_4px_2px_#1B222Bcc]"
      >
        <div
          class="mx-auto flex w-full max-w-5xl pl-4 lg:pl-0 pr-24 flex-wrap items-center justify-between gap-3"
        >
          <div class="fixed right-2 top-5 z-20 flex items-center gap-0.5 print-hidden">
            <a
              href={withBase(pdfHref)}
              download
              class="inline-flex rounded p-2 transition hover:bg-white/10"
              aria-label={data.pdfDownloadLabel}
            >
              <img
                src={withBase("/images/pdf.svg")}
                alt=""
                class="h-6 w-6 brightness-0 invert opacity-90"
              />
            </a>
            <a
              href={withBase(alternateHref)}
              class="inline-flex rounded p-2 transition hover:bg-white/10"
            >
              <img
                src={withBase(alternateFlagSrc)}
                alt={alternateFlagAlt}
                class="h-6 w-6"
              />
            </a>
          </div>
          <h1 class="text-4xl font-light leading-none text-[#3BA590]">
            {data.person.name}
          </h1>
          <div
            class="flex flex-wrap items-center md:justify-end gap-x-10 gap-y-3 text-[#F7FDED]"
          >
            <div class="flex items-center">
              <img
                src={withBase("/images/phone.svg")}
                alt={data.person.phoneLabel}
                class="mr-3 h-6 w-6"
              />
              <a
                href={data.person.phoneHref}
                class="no-underline inline-flex items-center rounded p-2 transition hover:bg-white/10"
                >{data.person.phone}</a
              >
            </div>
            <div class="flex items-center">
              <img
                src={withBase("/images/email.svg")}
                alt={data.person.emailLabel}
                class="mr-3 h-6 w-6"
              />
              <a
                href={data.person.emailHref}
                class="no-underline inline-flex items-center rounded p-2 transition hover:bg-white/10"
                >{data.person.email}</a
              >
            </div>
          </div>
        </div>
      </div>

      <section class="bg-[#1B222B] px-4 pb-10 pt-6 text-[#afafaf] md:pb-20">
        <div class="mx-auto max-w-5xl space-y-4 text-base md:text-lg">
          {
            data.intro.map((paragraph, index) =>
              index === data.intro.length - 1 ? (
                <p>
                  <span class="print:hidden" set:html={paragraph} />
                </p>
              ) : (
                <p set:html={paragraph} />
              ),
            )
          }
        </div>
      </section>

      <CvSection title={data.skills.title}>
        <div class="grid gap-10 md:grid-cols-3">
          {
            data.skills.items.map((item) => (
              <CvList title={item.title} items={item.list} />
            ))
          }
        </div>
      </CvSection>

      <CvSection
        title={data.projects.title}
        inverted
        sectionClass="featured-projects"
      >
        <div class="grid gap-16 md:grid-cols-2">
          {
            data.projects.items.map((project) => (
              <CvProject
                title={project.title}
                url={project.url}
                imageUrl={project.image}
                imageAlt={project.imageAlt}
              >
                {project.description}
              </CvProject>
            ))
          }
        </div>
      </CvSection>

      <CvSection title={data.tools.title} sectionClass="tools-section">
        <div class="grid gap-10 md:grid-cols-3">
          {
            data.tools.items.map((item) => (
              <CvList title={item.title} items={item.list} />
            ))
          }
        </div>
      </CvSection>

      <CvSection
        title={data.employment.title}
        sectionClass="employment-section"
        contentClass="pb-0 md:pb-0"
      >
        <CvTimeline items={data.employment.items} />
      </CvSection>

      <CvSection
        title={data.education.title}
        sectionClass="education-section"
        contentClass="pb-0 md:pb-0"
      >
        <div class="grid gap-10 md:grid-cols-3">
          {
            data.education.items.map((item) => (
              <CvList title={item.title} items={item.list} />
            ))
          }
        </div>
      </CvSection>
    </main>
    <footer class="mx-auto max-w-5xl px-4 py-8 text-sm text-[#666]">
      {data.footer}
    </footer>
  </body>
</html>
